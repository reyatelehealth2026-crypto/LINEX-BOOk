# =========================================================================
# LineBook — SaaS mode
# =========================================================================
# LineBook ตอนนี้เป็น multi-tenant SaaS:
#   - แต่ละร้านลงทะเบียนผ่าน /signup แล้วกรอก LINE credentials ของตัวเอง
#   - เซิร์ฟเวอร์เก็บ token/secret/LIFF ID ไว้ใน shops table (per-shop)
#   - subdomain เช่น mysalon.จองคิว.net จะ route ไปที่ร้านนั้น
#
# ENV vars ด้านล่างนี้เป็น **platform-level** เท่านั้น
# (ไม่ต้องใส่ credentials ของร้าน — ให้ใช้ /signup แทน)
# =========================================================================

# ---- Supabase (required) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- App domain / routing ----
# Root domain that serves the marketing + signup pages. Tenant apps are
# served at <slug>.${ROOT_DOMAIN}.  For local dev use "localhost" — then
# tenants live at e.g. http://mysalon.localhost:3000
# Either the Unicode (U-label) or Punycode (A-label) form is accepted — the
# proxy normalizes it before matching against the Host header.
# e.g. ROOT_DOMAIN=จองคิว.net  or  ROOT_DOMAIN=xn--42cfc0k1a8b.net
ROOT_DOMAIN=จองคิว.net
NEXT_PUBLIC_APP_URL=https://จองคิว.net
# Extra alias roots served by the same app (comma-separated). Leave blank
# unless you run multiple domains, e.g. ADDITIONAL_ROOT_DOMAINS=likesms.net
ADDITIONAL_ROOT_DOMAINS=likesms.net

# ---- Vercel Cron security ----
# Optional: if set, /api/cron/reminders requires `Authorization: Bearer <this>`.
CRON_SECRET=

# =========================================================================
# Legacy single-tenant fallbacks (OPTIONAL — only for the pre-SaaS mode
# where the whole deployment is one shop).  Leave blank for SaaS mode.
# =========================================================================
# LINE credentials used if a shop row has no token saved.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LIFF_ID=

# Default shop id used when request has no subdomain/context (cron fallback).
DEFAULT_SHOP_ID=1
SHOP_TIMEZONE=Asia/Bangkok

# Legacy admin auth — new tenants use per-shop admin_users rows created
# during /signup.  These are only consulted as a fallback when a shop has
# no admin_users rows yet.
ADMIN_PASSWORD=
ADMIN_LINE_IDS=
ADMIN_CHAT_SESSION_HOURS=12
