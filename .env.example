# =========================================================================
# LineBook — SaaS mode
# =========================================================================
# LineBook ตอนนี้เป็น multi-tenant SaaS:
#   - แต่ละร้านลงทะเบียนผ่าน /signup แล้วกรอก LINE credentials ของตัวเอง
#   - เซิร์ฟเวอร์เก็บ token/secret/LIFF ID ไว้ใน shops table (per-shop)
#   - subdomain เช่น mysalon.จองคิว.net จะ route ไปที่ร้านนั้น
#
# ENV vars ด้านล่างนี้เป็น **platform-level** เท่านั้น
# (ไม่ต้องใส่ credentials ของร้าน — ให้ใช้ /signup แทน)
# =========================================================================

# ---- Supabase (required) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- App domain / routing ----
# Root domain that serves the marketing + signup pages. Tenant apps are
# served at <slug>.${ROOT_DOMAIN}.  For local dev use "localhost" — then
# tenants live at e.g. http://mysalon.localhost:3000
# Either the Unicode (U-label) or Punycode (A-label) form is accepted — the
# proxy normalizes it before matching against the Host header.
# e.g. ROOT_DOMAIN=จองคิว.net  or  ROOT_DOMAIN=xn--42cfc0k1a8b.net
ROOT_DOMAIN=จองคิว.net
NEXT_PUBLIC_APP_URL=https://จองคิว.net
# Extra alias roots served by the same app (comma-separated). Leave blank
# unless you run multiple domains, e.g. ADDITIONAL_ROOT_DOMAINS=likesms.net
ADDITIONAL_ROOT_DOMAINS=likesms.net

# ---- AI / Gemini (multimodal chat + vision + image generation) ----
# Required for AI chat, vision analysis, and image generation features.
GEMINI_API_KEY=

# Vision model — used when a customer sends an image (Phase 1: vision).
# gemini-2.5-flash is GA and supports multimodal image input.
GEMINI_VISION_MODEL=gemini-2.5-flash

# Image generation model — used when a customer requests a preview image (Phase 2).
# gemini-2.5-flash-image is GA and optimised for high-volume generation.
GEMINI_IMAGE_GEN_MODEL=gemini-2.5-flash-image

# Chat model for text conversations (per-shop override stored in ai_settings table).
# Thinking disabled by default (0) — faster/cheaper for customer-facing chat.
# GEMINI_THINKING_BUDGET=0
# GEMINI_TIMEOUT_MS=20000

# Feature flags — set to "false" to disable globally (per-shop toggle also in ai_settings).
# Vision defaults ON (low cost). Image gen defaults OFF (higher cost — enable when ready).
# AI_VISION_ENABLED=true
# AI_IMAGE_GEN_ENABLED=false

# Fallback model chain when primary fails (comma-separated).
# AI_FALLBACK_MODELS=gemini-2.5-flash,glm-4.5-air

# Z.AI / GLM credentials (alternative AI provider).
ZAI_API_KEY=
# ZAI_API_URL=https://api.z.ai/api/coding/paas/v4/chat/completions

# ---- Vercel Cron security ----
# Optional: if set, /api/cron/reminders requires `Authorization: Bearer <this>`.
CRON_SECRET=

# ---- Vercel API (per-subdomain attach on signup) ----
# If all three are set, /api/signup/create will attach {slug}.{ROOT_DOMAIN}
# to the Vercel project so Vercel auto-issues a per-subdomain HTTP-01 cert.
# This is the workaround for running on Vercel while DNS stays on a
# third-party nameserver (wildcard certs require Vercel-hosted DNS).
# Omit all three to skip the attach — signup will still succeed and fall
# back to the path-based entry URL (${ROOT_DOMAIN}/<slug>/admin/...).
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# =========================================================================
# Legacy single-tenant fallbacks (OPTIONAL — only for the pre-SaaS mode
# where the whole deployment is one shop).  Leave blank for SaaS mode.
# =========================================================================
# LINE credentials used if a shop row has no token saved.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LIFF_ID=

# Default shop id used when request has no subdomain/context (cron fallback).
DEFAULT_SHOP_ID=1
SHOP_TIMEZONE=Asia/Bangkok

# Legacy admin auth — new tenants use per-shop admin_users rows created
# during /signup.  These are only consulted as a fallback when a shop has
# no admin_users rows yet.
ADMIN_PASSWORD=
ADMIN_LINE_IDS=
ADMIN_CHAT_SESSION_HOURS=12
