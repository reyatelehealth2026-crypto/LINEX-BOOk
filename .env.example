# ---- LINE Messaging API (from LINE Developers Console) ----
LINE_CHANNEL_ACCESS_TOKEN=your_messaging_api_long_lived_token
LINE_CHANNEL_SECRET=your_messaging_api_channel_secret

# ---- LINE LIFF ----
NEXT_PUBLIC_LIFF_ID=1234567890-abcdefgh

# ---- Supabase (create at https://supabase.com) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- App ----
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app
SHOP_TIMEZONE=Asia/Bangkok
DEFAULT_SHOP_ID=1

# ---- Admin (simple shared password for MVP) ----
ADMIN_PASSWORD=change-me
ADMIN_CHAT_SESSION_HOURS=12

# ---- Admin LINE user IDs (comma-separated, starts with U...) ----
# Used by:
#  - chat-based admin (/api/line/webhook)
#  - LIFF admin area at /liff/admin (no password needed)
# Find your LINE user ID by opening /liff/admin once — the error screen
# will show your userId which you can paste here.
ADMIN_LINE_IDS=Uxxxxxxxxxxxxx
